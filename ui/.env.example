# Backend base URL
# Local: http://localhost:8000
# Production: https://your-backend.railway.app
API_URL=http://localhost:8000

# Streamlit built-in auth
STREAMLIT_AUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
STREAMLIT_AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
STREAMLIT_AUTH_REDIRECT_URI=http://localhost:8501/oauth2callback
STREAMLIT_AUTH_COOKIE_SECRET=any-random-string
STREAMLIT_AUTH_EXPOSE_TOKENS=true
STREAMLIT_AUTH_SERVER_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration
