# OpenAI: platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Canvas LMS base URL: your institution's Canvas domain
CANVAS_BASE_URL=https://canvas.instructure.com

# Canvas API token: Canvas > Account > Settings > New Access Token
CANVAS_TOKEN=

# Canvas MCP URL: set automatically in docker-compose, override for Railway
# Local (outside docker): http://localhost:8001/sse
# Railway: http://canvas-mcp.railway.internal:8001/sse
CANVAS_MCP_URL=http://localhost:8001/sse

# Frontend URL: used for CORS
# Local: http://localhost:8501
# Production: https://your-frontend.railway.app
FRONTEND_URL=http://localhost:8501

# LangSmith observability: smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=study-pilot
LANGCHAIN_TRACING_V2=true
